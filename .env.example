# Copy this to .env and fill in your values

# Concept2 OAuth credentials (from https://log.concept2.com/developers/home)
C2_CLIENT_ID=your_client_id_here
C2_CLIENT_SECRET=your_client_secret_here

# Long-lived access token obtained by running:  python -m concept2_pipeline.auth
# After the browser OAuth flow completes this will be printed and saved.
C2_ACCESS_TOKEN=your_access_token_here

# Postgres connection string (matches docker-compose defaults)
PG_CONN=postgresql://concept2:concept2pass@localhost:5432/concept2
